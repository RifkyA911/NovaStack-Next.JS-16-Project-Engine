NEXT_PUBLIC_BASE_URL='http://localhost:3000'
NEXT_PUBLIC_BASE_API_URL='http://localhost:3000/api'
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_SERVER_HOST='localhost'
NEXT_PUBLIC_SERVER_PORT=3000
# NEXT_PUBLIC_BASE_API_URL=http://localhost/api
NEXT_PUBLIC_BASE_API_URL='https://jsonplaceholder.typicode.com/'

NEXT_PUBLIC_JWT_SECRET='your_jwt_secret_key'
NEXT_PUBLIC_JWT_EXPIRES_IN='1h'

NEXTAUTH_SECRET='supersecretkey'
NEXTAUTH_URL='http://localhost:3000'

# Google OAuth
GOOGLE_CLIENT_ID=xxxxx
GOOGLE_CLIENT_SECRET=xxxxx

# reCAPTCHA v3 (Google) - Primary
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY='your-recaptcha-site-key-here'
RECAPTCHA_V3_SECRET_KEY='your-recaptcha-secret-key-here'

# reCAPTCHA v2 (Google) - Fallback
NEXT_PUBLIC_RECAPTCHA_V2_SITE_KEY='your-recaptcha-site-key-here'
RECAPTCHA_V2_SECRET_KEY='your-recaptcha-secret-key-here'

# Site Configuration
NEXT_PUBLIC_SITE_TYPE='internal' # 'public' or 'internal'
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION='your-google-site-verification-code'
NEXT_PUBLIC_YANDEX_VERIFICATION='your-yandex-verification-code'

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_API_MAX=30
RATE_LIMIT_API_WINDOW_MS=60000

# Logger
LOGGER_ENABLED=false
LOGGER_LEVEL=info
